# ============================================================
# Chain News Japan — 環境変数テンプレート
# このファイルをコピーして .env.local を作成してください。
# .env.local は .gitignore 済みのため Git にコミットされません。
# ============================================================

# Google Analytics 4 測定ID（例: G-XXXXXXXXXX）
# GA4 プロパティの「管理 > データストリーム」で確認できます。
# 未設定の場合は GA タグは挿入されません。
NEXT_PUBLIC_GA_ID=

# Google AdSense クライアントID（例: ca-pub-1234567890123456）
# 未設定の場合、広告枠はプレースホルダ表示のままになります。
NEXT_PUBLIC_ADSENSE_CLIENT=

# 各広告枠に使う AdSense のスロットID
NEXT_PUBLIC_ADSENSE_SLOT_BANNER=
NEXT_PUBLIC_ADSENSE_SLOT_RECTANGLE=
NEXT_PUBLIC_ADSENSE_SLOT_LEADERBOARD=

# サイトのベース URL（OGP・sitemap・robots.txt に使われます）
# Vercel にデプロイした後、実際の URL に更新してください。
NEXT_PUBLIC_SITE_URL=https://chain-news-japan.vercel.app
